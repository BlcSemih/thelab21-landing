---
---

<section class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-8 animate-fade-in-up">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        <span class="text-sm text-gray-300">Digitales Studio aus Stuttgart</span>
      </div>

      <!-- Main Heading -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold mb-6 animate-fade-in-up animation-delay-200">
        Wir entwickeln
        <br />
        <span class="gradient-text">innovative Software</span>
      </h1>

      <!-- Subheading -->
      <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10 animate-fade-in-up animation-delay-400">
        Von der Idee zum fertigen Produkt. Wir bauen digitale Lösungen,
        die echte Probleme lösen und Menschen begeistern.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up animation-delay-600">
        <a href="#produkte" class="w-full sm:w-auto px-8 py-4 bg-primary-600 hover:bg-primary-500 text-white rounded-xl font-semibold transition-all hover:scale-105 hover:shadow-lg hover:shadow-primary-600/25">
          Unsere Produkte
        </a>
        <a href="#kontakt" class="w-full sm:w-auto px-8 py-4 glass hover:bg-white/10 text-white rounded-xl font-semibold transition-all">
          Kontakt aufnehmen
        </a>
      </div>

      <!-- Scroll Indicator -->
      <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </div>
  </div>

  <!-- Decorative Elements -->
  <div class="absolute top-1/3 left-10 w-20 h-20 border border-primary-500/20 rounded-2xl rotate-12 animate-float"></div>
  <div class="absolute bottom-1/3 right-10 w-16 h-16 border border-purple-500/20 rounded-full animate-float" style="animation-delay: 1.5s;"></div>
  <div class="absolute top-1/2 right-1/4 w-12 h-12 bg-primary-500/10 rounded-lg rotate-45 animate-float" style="animation-delay: 0.5s;"></div>
</section>
