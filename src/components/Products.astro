---
---

<section id="produkte" class="py-24 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
        Unsere <span class="gradient-text">Produkte</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Software, die echte Probleme löst und Menschen im Alltag unterstützt.
      </p>
    </div>

    <!-- Products Grid -->
    <div class="grid md:grid-cols-2 gap-8">
      <!-- AP1-Trainer -->
      <div class="glass rounded-3xl p-8 card-hover group relative overflow-hidden">
        <!-- Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-br from-primary-600/10 to-purple-600/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>

        <div class="relative">
          <!-- Product Icon -->
          <div class="w-16 h-16 rounded-2xl overflow-hidden mb-6 group-hover:scale-110 transition-transform">
            <img src="/ap1-trainer-logo.svg" alt="AP1-Trainer Logo" class="w-full h-full" />
          </div>

          <!-- Badge -->
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-green-500/20 text-green-400 text-sm mb-4">
            <span class="w-2 h-2 rounded-full bg-green-400"></span>
            Live
          </div>

          <!-- Title & Description -->
          <h3 class="text-2xl font-bold text-white mb-3">AP1-Trainer</h3>
          <p class="text-gray-400 mb-6">
            Die Lernplattform für IT-Azubis. Bereite dich optimal auf die IHK AP1-Prüfung vor
            mit über 1.200 Quiz-Fragen, Lernkarten und umfassenden Zusammenfassungen.
          </p>

          <!-- Features -->
          <ul class="space-y-3 mb-8">
            <li class="flex items-center gap-3 text-gray-300">
              <svg class="w-5 h-5 text-primary-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Quiz-System mit allen IHK-Themen
            </li>
            <li class="flex items-center gap-3 text-gray-300">
              <svg class="w-5 h-5 text-primary-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Digitale Lernkarten
            </li>
            <li class="flex items-center gap-3 text-gray-300">
              <svg class="w-5 h-5 text-primary-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Fortschrittsverfolgung & Statistiken
            </li>
          </ul>

          <!-- CTA -->
          <a href="https://ap1-trainer.de" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white rounded-xl font-semibold transition-all hover:scale-105">
            Jetzt ausprobieren
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Dashboard -->
      <div class="glass rounded-3xl p-8 card-hover group relative overflow-hidden">
        <!-- Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-br from-cyan-600/10 to-blue-600/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>

        <div class="relative">
          <!-- Product Icon -->
          <div class="w-16 h-16 rounded-2xl overflow-hidden mb-6 group-hover:scale-110 transition-transform">
            <img src="/thelab21-logo.svg" alt="theLab21 Dashboard Logo" class="w-full h-full" />
          </div>

          <!-- Badge -->
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/20 text-blue-400 text-sm mb-4">
            <span class="w-2 h-2 rounded-full bg-blue-400"></span>
            Intern
          </div>

          <!-- Title & Description -->
          <h3 class="text-2xl font-bold text-white mb-3">theLab21 Dashboard</h3>
          <p class="text-gray-400 mb-6">
            Unser internes Tool für Projekt- und Ticketmanagement. Mit KI-Unterstützung,
            E-Mail-Integration und automatisierter Workflows.
          </p>

          <!-- Features -->
          <ul class="space-y-3 mb-8">
            <li class="flex items-center gap-3 text-gray-300">
              <svg class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              Kanban-Board mit Drag & Drop
            </li>
            <li class="flex items-center gap-3 text-gray-300">
              <svg class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              KI-gestützte Ticket-Klassifizierung
            </li>
            <li class="flex items-center gap-3 text-gray-300">
              <svg class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              E-Mail zu Ticket Automatisierung
            </li>
          </ul>

          <!-- Info text instead of CTA -->
          <div class="inline-flex items-center gap-2 px-6 py-3 bg-gray-700/50 text-gray-400 rounded-xl font-medium">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
            Nur für interne Nutzung
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
