---
---

<section id="team" class="py-24 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4">
        Das <span class="gradient-text">Team</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Zwei Entwickler mit einer gemeinsamen Vision: Software bauen, die einen Unterschied macht.
      </p>
    </div>

    <!-- Team Grid -->
    <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- Semih -->
      <div class="glass rounded-3xl p-8 card-hover group text-center">
        <!-- Avatar -->
        <div class="w-32 h-32 mx-auto mb-6 rounded-full bg-gradient-to-br from-primary-500 to-purple-600 p-1 group-hover:scale-105 transition-transform">
          <img src="/team-semih.png" alt="Semih" class="w-full h-full rounded-full object-cover" />
        </div>

        <!-- Info -->
        <h3 class="text-2xl font-bold text-white mb-2">Semih</h3>
        <p class="text-primary-400 font-medium mb-4">Gründer & Entwickler</p>
        <p class="text-gray-400 mb-6">
          FISI-Azubi mit Leidenschaft für Full-Stack Development. Baut die technische
          Infrastruktur und entwickelt neue Features für alle Produkte.
        </p>

        <!-- Skills -->
        <div class="flex flex-wrap justify-center gap-2">
          <span class="px-3 py-1 rounded-full bg-primary-500/20 text-primary-400 text-sm">TypeScript</span>
          <span class="px-3 py-1 rounded-full bg-primary-500/20 text-primary-400 text-sm">React</span>
          <span class="px-3 py-1 rounded-full bg-primary-500/20 text-primary-400 text-sm">Next.js</span>
          <span class="px-3 py-1 rounded-full bg-primary-500/20 text-primary-400 text-sm">Supabase</span>
        </div>
      </div>

      <!-- Maxi -->
      <div class="glass rounded-3xl p-8 card-hover group text-center">
        <!-- Avatar -->
        <div class="w-32 h-32 mx-auto mb-6 rounded-full bg-gradient-to-br from-cyan-500 to-blue-600 p-1 group-hover:scale-105 transition-transform">
          <div class="w-full h-full rounded-full bg-dark-800 flex items-center justify-center">
            <span class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">MX</span>
          </div>
        </div>

        <!-- Info -->
        <h3 class="text-2xl font-bold text-white mb-2">Maxi</h3>
        <p class="text-cyan-400 font-medium mb-4">Partner & Entwickler</p>
        <p class="text-gray-400 mb-6">
          Kreativer Kopf mit Auge fürs Detail. Verantwortlich für UI/UX Design
          und sorgt dafür, dass alles nicht nur funktioniert, sondern auch gut aussieht.
        </p>

        <!-- Skills -->
        <div class="flex flex-wrap justify-center gap-2">
          <span class="px-3 py-1 rounded-full bg-cyan-500/20 text-cyan-400 text-sm">UI/UX</span>
          <span class="px-3 py-1 rounded-full bg-cyan-500/20 text-cyan-400 text-sm">Design</span>
          <span class="px-3 py-1 rounded-full bg-cyan-500/20 text-cyan-400 text-sm">Frontend</span>
          <span class="px-3 py-1 rounded-full bg-cyan-500/20 text-cyan-400 text-sm">CSS</span>
        </div>
      </div>
    </div>
  </div>
</section>
