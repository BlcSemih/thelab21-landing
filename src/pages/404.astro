---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Seite nicht gefunden | theLab21">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center">
      <!-- 404 Number -->
      <h1 class="text-8xl sm:text-9xl font-bold gradient-text mb-4">404</h1>

      <!-- Message -->
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">
        Seite nicht gefunden
      </h2>
      <p class="text-gray-400 text-lg mb-8 max-w-md mx-auto">
        Die gesuchte Seite existiert nicht oder wurde verschoben.
      </p>

      <!-- Back Button -->
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white rounded-xl font-semibold transition-all hover:scale-105"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Zurück zur Startseite
      </a>
    </div>
  </div>
</Layout>
